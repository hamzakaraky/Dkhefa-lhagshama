{
  "name": "push-for-fulfillment-backend",
  "version": "0.1.0",
  "description": "Express + Firebase Admin backend for the Push for Fulfillment community platform.",
  "private": true,
  "main": "dist/function.js",
  "scripts": {
    "dev": "nodemon",
    "build": "tsc && tsc-alias",
    "start": "node dist/index.js",
    "lint": "eslint src --ext .ts",
    "lint:fix": "eslint src --ext .ts --fix",
    "type-check": "tsc --noEmit",
    "test": "jest",
    "seed": "ts-node --project tsconfig.scripts.json scripts/seed.ts",
    "seed:orgs": "ts-node --project tsconfig.scripts.json scripts/seedOrgs.ts",
    "set-admin": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/setAdminClaim.ts",
    "set-volunteer": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/setVolunteerClaim.ts",
    "set-roles": "ts-node --project tsconfig.scripts.json -r tsconfig-paths/register scripts/setRoles.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.5.1",
    "firebase-admin": "^12.4.0",
    "firebase-functions": "^6.0.1",
    "helmet": "^8.2.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^20.14.0",
    "@typescript-eslint/eslint-plugin": "^7.13.0",
    "@typescript-eslint/parser": "^7.13.0",
    "eslint": "^8.57.0",
    "jest": "^29.7.0",
    "nodemon": "^3.1.4",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "tsc-alias": "^1.8.10",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.4.5"
  },
  "engines": {
    "node": ">=20"
  }
}
